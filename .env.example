# ═══════════════════════════════════════════════════
# VedaFlow (EduFlow) — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/school_saas
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/school_saas

# Security — CHANGE THESE IN PRODUCTION!
SECRET_KEY=generate-a-64-char-random-string-here
DEBUG=false

# Super Admin (initial setup only)
SUPER_ADMIN_EMAIL=admin@eduflow.in
SUPER_ADMIN_PASSWORD=ChangeThisPassword123!
SUPER_ADMIN_PHONE=9999999999

# File uploads
UPLOAD_DIR=static/uploads

# Online Classes — OAuth credentials (optional, per-platform)
# Google Meet (requires Google Workspace + Calendar API enabled)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft Teams (requires Azure AD app registration)
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
