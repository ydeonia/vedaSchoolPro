# EduFlow — Environment Variables
# Copy this to .env and update values for your environment

# Database
DATABASE_URL=postgresql+asyncpg://postgres:admin@localhost:5432/school_saas
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:admin@localhost:5432/school_saas
SECRET_KEY=eduflow-secret-key-change-in-production-2026
# Security
SECRET_KEY=your-super-secret-key-change-in-production-make-it-long-and-random
# In your .env or environment
QR_SECRET_KEY=YourOwnSuperSecretKey-Change-This-2025!
# Super Admin Credentials
SUPER_ADMIN_EMAIL=admin@eduflow.in
SUPER_ADMIN_PASSWORD=Admin@123
SUPER_ADMIN_PHONE=9999999999

# File Uploads
UPLOAD_DIR=static/uploads
